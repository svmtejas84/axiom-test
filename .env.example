# Axiom Credit Platform - Environment Variables Example
# Copy this file to .env and fill in your actual credentials.

# --- Setu Account Aggregator (Sandbox) ---
# Get these from https://bridge.setu.co/
SETU_AA_API_KEY=your_setu_api_key_here
SETU_AA_SECRET=your_setu_secret_here
SETU_AA_BASE_URL=https://sandbox.setu.co
SETU_AA_TIMEOUT_SECONDS=30

# --- Databases ---
# PostgreSQL (for structured scores and users)
DATABASE_URL=postgresql+asyncpg://axiom_user:axiom_password@localhost:5432/axiom_db

# MongoDB (for raw transaction JSON and unstructured data)
MONGODB_URL=mongodb://axiom_user:axiom_password@localhost:27017/axiom_db

# Redis (for caching scores and session data)
REDIS_URL=redis://localhost:6379/0

# --- App Configuration ---
DEBUG=True
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Scoring Logic Thresholds ---
# Maximum tenants allowed per landlord before flagging "herd behavior" fraud
AXIOM_MAX_TENANTS_PER_LANDLORD=3

# Minimum behavioral signals required for high-confidence scoring
AXIOM_CONFIDENCE_SIGNAL_THRESHOLD=20
